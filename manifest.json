{
  "manifest_version": 3,
  "name": "MediCenter Report Extractor",
  "version": "1.0.0",
  "description": "Automatiza la extracción de reportes desde el portal HIS MediCenter.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://his.medicenter.cl/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
